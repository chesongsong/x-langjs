{
  "name": "@x-langjs/core",
  "version": "0.0.5",
  "description": "Core package for x-langjs — parse, tokenize, and work with x-langjs AST",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build"
  },
  "dependencies": {
    "@x-langjs/types": "workspace:*",
    "@x-langjs/parser": "workspace:*",
    "@x-langjs/ast": "workspace:*",
    "@x-langjs/interpreter": "workspace:*",
    "@x-langjs/render": "workspace:*",
    "antlr4ng": "^3.0.16"
  },
  "keywords": [
    "x-langjs",
    "xlang",
    "antlr4",
    "dsl",
    "parser",
    "interpreter",
    "renderer"
  ]
}
