{
  "name": "@x-langjs/parser",
  "version": "0.0.3",
  "description": "ANTLR4-based lexer and parser for x-lang",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "antlr-ng -Dlanguage=TypeScript -v -o src/generated --exact-output-dir grammar/XLangLexer.g4 grammar/XLangParser.g4",
    "build": "tsc --build"
  },
  "dependencies": {
    "@x-langjs/types": "workspace:*",
    "antlr4ng": "^3.0.16"
  }
}
