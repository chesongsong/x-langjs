{
  "name": "@x-langjs/parser",
  "version": "0.0.5",
  "description": "ANTLR4-based lexer and parser for x-langjs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "generate": "antlr-ng -Dlanguage=TypeScript -v -o src/generated --exact-output-dir grammar/XLangLexer.g4 grammar/XLangParser.g4",
    "build": "tsc --build"
  },
  "dependencies": {
    "@x-langjs/types": "workspace:*",
    "antlr4ng": "^3.0.16"
  },
  "keywords": [
    "x-langjs",
    "xlang",
    "antlr4",
    "antlr4ng",
    "lexer",
    "parser",
    "dsl"
  ]
}
